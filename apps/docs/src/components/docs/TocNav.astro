---
interface TocHeading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  items: TocHeading[];
}

const { items } = Astro.props as Props;
---

{
  items.length > 0 && (
    <aside class="flex h-[calc(100dvh-2rem)] min-h-0 flex-col rounded-3xl border border-zinc-200/80 bg-white/75 p-4 backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/70">
      <p class="shrink-0 text-[11px] tracking-[0.16em] text-zinc-500 uppercase">On This Page</p>
      <div class="mt-3 min-h-0 flex-1 overflow-y-auto pr-1">
        <ul class="space-y-1">
          {items.map((item) => (
            <li class:list={[item.depth > 2 && 'pl-3']}>
              <a
                href={`#${item.slug}`}
                class="block rounded-lg px-2 py-1.5 text-sm text-zinc-600 hover:bg-zinc-100 hover:text-zinc-950 dark:text-zinc-300 dark:hover:bg-zinc-900 dark:hover:text-zinc-50"
              >
                {item.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </aside>
  )
}
